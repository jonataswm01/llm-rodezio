# OpenAI (required for the agent)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini

# Redis (memória de conversa — persistência do histórico por thread/telefone)
REDIS_URL=redis://default:senha@host:6389

# Elasticsearch (para pesquisa de fretes)
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_FRETES=fretes
# Raio de busca geo (km) para origin/destination. Padrão: 300
ELASTICSEARCH_GEO_RADIUS_KM=300
# Autenticação (opcional; se não informar, conecta sem auth — útil para ES local)
ELASTICSEARCH_USER=elastic
ELASTICSEARCH_PASSWORD=changeme

# API de localização (geolocalização para origem/destino)
SAG_BACKEND_URL=https://sag-backend.roduno.work

# Logs verbosos (passo a passo + pensamento da IA). true = ativa
RODEZIO_DEBUG=false

# n8n (webhook para fluxo contratar frete)
N8N_WEBHOOK_CONTRATAR_FRETE=https://seu-n8n.com/webhook/contratar-frete
# n8n (webhook para fluxo cotação de frete)
N8N_WEBHOOK_FRETE_COTACAO=https://llm-llm-n8n.bmlwrg.easypanel.host/webhook/frete-cotacao

# LangSmith (obrigatório para ver runs no LangGraph Studio; opcional para tracing)
# Nome exato: LANGSMITH_API_KEY. Valor sem aspas, sem espaços. Obtenha em: https://smith.langchain.com/settings
LANGSMITH_API_KEY=lsv2_pt_xxxxxxxx
LANGSMITH_PROJECT=llm-rodezio-agent
LANGSMITH_WORKSPACE=default
# LANGSMITH_WORKSPACE_ID=uuid-do-workspace (opcional, mais preciso que LANGSMITH_WORKSPACE)
LANGSMITH_TRACING=false





