{
  "$schema": "https://www.schemastore.org/tsconfig",
  "_version": "22.0.0",

  "include": ["src/**/*"],
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "lib": ["es2022", "esnext"],
    "module": "nodenext",
    "target": "es2022",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node16",

    "paths": {
      "@/*": ["./src/*"]
    }
  }
}
